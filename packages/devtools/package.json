{
  "name": "@mutaflow/devtools",
  "version": "0.1.2",
  "description": "Devtools prototype for Mutaflow mutation timelines",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/javaquasar/mutaflow.git",
    "directory": "packages/devtools"
  },
  "homepage": "https://github.com/javaquasar/mutaflow#readme",
  "bugs": {
    "url": "https://github.com/javaquasar/mutaflow/issues"
  },
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "prepublishOnly": "npm run build"
  },
  "peerDependencies": {
    "mutaflow": "^0.1.2",
    "react": ">=19.0.0"
  },
  "devDependencies": {
    "mutaflow": "file:../mutaflow"
  }
}
